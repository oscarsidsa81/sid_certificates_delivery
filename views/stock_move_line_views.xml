<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_move_line_certificate_tree" model="ir.ui.view">
        <field name="name">certificate.stock.move.line.tree</field>
        <field name="model">stock.move.line</field>
        <field name="arch" type="xml">
            <tree string="Líneas de movimiento con certificados">
                <field name="picking_id"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="qty_done"/>
                <field name="certificate_id"/>
                <field name="certificate_ids" widget="many2many_tags"/>
                <field name="certificate_ids_name"/>
                <field name="certificate_qty_received"/>
                <field name="certificate_date"/>
                <field name="update_certificate_value"/>
            </tree>
        </field>
    </record>

    <record id="view_stock_move_line_tree_inherit_certificate" model="ir.ui.view">
        <field name="name">certificate_view_move_line_tree.inherit</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_id']" position="after">
                <field name="certificate_id" optional="show"/>
                <field name="certificate_ids" widget="many2many_tags" optional="hide"/>
                <field name="certificate_qty_received" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="action_stock_move_line_certificates" model="ir.actions.act_window">
        <field name="name">Movimientos con certificados</field>
        <field name="res_model">stock.move.line</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_stock_move_line_certificate_tree"/>
        <field name="domain">['|', ('certificate_id','!=',False), ('certificate_ids','!=',False)]</field>
    </record>

    <menuitem id="menu_stock_move_line_certificates" name="Movimientos con certificados" parent="menu_inventory_certificate_root" action="action_stock_move_line_certificates" sequence="40"/>
</odoo>
